# Spotify API credentials
CLIENT_ID=your_spotify_client_id
CLIENT_SECRET=your_spotify_client_secret

# Backend OAuth redirect — must match EXACTLY this URI in Spotify Developer Dashboard (Redirect URIs).
REDIRECT_URI=http://127.0.0.1:3000/auth/callback

# Frontend callback URL (must match Spotify app settings)
SPOTIFY_REDIRECT_URI=http://127.0.0.1:4200/callback

# Frontend -> Backend API URL used at build time
API_URL=http://127.0.0.1:3000

# Backend CORS/frontend URL
FRONTEND_URL=http://127.0.0.1:4200

# Optional AI genre fallback (Gemini). Required for [genre] AI logs / unmapped artists.
# Docker (repo root): add this to .env — docker-compose.yml uses env_file: .env and passes GEMINI_API_KEY into the api container (no file needed inside /app).
GEMINI_API_KEY=
# Optional; default is gemini-2.5-flash (gemini-2.0-flash returns 404 for new API users).
# GEMINI_MODEL=
# Per-request Gemini timeout in seconds (default 25, max 120). Raise if you see context deadline exceeded.
# GEMINI_REQUEST_TIMEOUT_SEC=25
# Batch AI genre fallback: artists per Gemini JSON batch (default 24, max 100).
# GEMINI_GENRE_BATCH_SIZE=24
# Max parallel Gemini batch chunks (default 2, max 16).
# GEMINI_GENRE_BATCH_PARALLEL=2
# Redis TTL for per-artist canonical genre after AI (seconds; default 7 days).
# ARTIST_AI_GENRE_CACHE_TTL_SEC=604800
# HTTP write timeout for long /track/summary (many AI calls). Default 360 seconds.
# HTTP_WRITE_TIMEOUT_SEC=360
